{
  "name": "@floto/client",
  "version": "0.1.0",
  "description": "Typescript API client for floto",
  "main": "dist/index.js",
  "keywords": [
    "typescript"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:int": "jest -c jest.config.int.ts --reporters=default --reporters=jest-junit",
    "coverage": "jest --coverage --coverageReporters=cobertura --reporters=default --reporters=jest-junit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --config .prettierrc 'src/**/*.ts' --write"
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "prettier": "^2.8.8",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
